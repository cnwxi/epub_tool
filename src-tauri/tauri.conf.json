{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Epub Tool NewUI",
  "identifier": "com.cnwxi.epubtool.newui",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "npm run dev:desktop"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "npm run build:bundle-assets"
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Epub Tool NewUI",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true,
        "transparent": true,
        "decorations": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "bundle-resources/binaries/epub-tool-python": "binaries/epub-tool-python-runtime",
      "bundle-resources/ocr-models/PP-OCRv6_small_rec_onnx/*": "ocr-models/PP-OCRv6_small_rec_onnx/"
    },
    "icon": [
      "../assets/img/icon.png",
      "../assets/img/icon.ico",
      "../assets/img/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}
